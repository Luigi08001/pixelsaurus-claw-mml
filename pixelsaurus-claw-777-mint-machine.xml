  <m-interaction id="machine-lever-interaction" x="2.3" y="2.52" z="1.0" range="4" priority="1" prompt="Pull 777 lever" oninteract="spinMachine()"></m-interaction>

  <script>
    const reelIds = ["reel-one", "reel-two", "reel-three"];
    const status = document.getElementById("machine-status");
    const button = document.getElementById("mint-button-face");
    const jackpot = document.getElementById("jackpot-banner");
    const glyphMintUrl = "https://opensea.io/collection/pixelsaurus-claw/overview";
    let spins = 0;

    function setReels(values) {
      reelIds.forEach((id, index) => {
        document.getElementById(id).setAttribute("content", values[index]);
      });
    }

    function spinMachine() {
      spins += 1;
      const jackpotMode = spins % 2 === 1;
      button.setAttribute("color", jackpotMode ? "#FF2B7A" : "#00F5D4");
      jackpot.setAttribute("color", jackpotMode ? "#D6B65A" : "#FF2B7A");
      setReels(jackpotMode ? ["P", "S", "C"] : ["7", "7", "7"]);
      status.setAttribute("content", jackpotMode ? "GLYPH READY" : "PULL LEVER");

      if (globalThis.ODKGlyphMint) {
        if (typeof globalThis.ODKGlyphMint.requestMint === "function") {
          globalThis.ODKGlyphMint.requestMint({
            collectionSlug: "pixelsaurus-claw",
            mintUrl: glyphMintUrl,
            source: "pixelsaurus-claw-777-mint-machine"
          });
        }
      }
    }
  </script>
