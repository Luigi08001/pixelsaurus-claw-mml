  <m-cube id="slot-face-inset" x="0" y="1.9" z="0.72" width="3.12" height="2.42" depth="0.08" color="#111C20"></m-cube>
  <m-cube id="slot-kick" x="0" y="0.45" z="0.68" width="3.86" height="0.64" depth="0.2" color="#071014"></m-cube>

  <m-cube id="lime-edge-top" x="0" y="3.38" z="0.82" width="3.7" height="0.08" depth="0.11" color="#73FF00" emissive="0.55"></m-cube>
  <m-cube id="lime-edge-bottom" x="0" y="0.66" z="0.82" width="3.62" height="0.08" depth="0.11" color="#73FF00" emissive="0.42"></m-cube>
