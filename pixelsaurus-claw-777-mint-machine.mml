  <m-cube id="lime-edge-right" x="1.82" y="2.01" z="0.82" width="0.08" height="2.68" depth="0.11" color="#73FF00" emissive="0.38"></m-cube>
  <m-cube id="magenta-left-stripe" x="-1.58" y="1.92" z="0.86" width="0.06" height="2.12" depth="0.1" color="#FF00C8" emissive="0.5"></m-cube>
  <m-cube id="magenta-right-stripe" x="1.58" y="1.92" z="0.86" width="0.06" height="2.12" depth="0.1" color="#FF00C8" emissive="0.5"></m-cube>

  <m-cube id="marquee-shell" x="0" y="3.72" z="0.62" width="3.72" height="0.84" depth="0.3" color="#081014"></m-cube>
